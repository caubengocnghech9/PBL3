@model List<PBL3.Models.PhieuMuon>
@{
    Layout = null;
    var tenNguoiDung = Context.Session.GetString("TenDangNhap") ?? "Độc giả";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phiếu mượn của tôi - LibraryPro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f7fc;
        }</style>
</head>
<body class="text-[#1e2a3e]">

    <nav class="bg-white shadow-sm border-b border-[#e2e8f0] sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <div class="w-10 h-10 bg-[#3b6cb7] text-white rounded-xl flex items-center justify-center text-xl">
                        <i class="fa-solid fa-book-open"></i>
                    </div>
                    <span class="font-bold text-xl text-[#3b6cb7]">LibraryPro</span>
                </div>

                <div class="hidden md:flex space-x-8">
                    <a href="/Home/TrangChuUser" class="text-[#64748b] hover:text-[#3b6cb7] font-medium px-1 py-5 transition">Thư viện sách</a>
                    <a href="/Home/PhieuMuon" class="text-[#3b6cb7] font-semibold border-b-2 border-[#3b6cb7] px-1 py-5">Phiếu mượn của tôi</a>
                    <a href="/Home/ThongTinCaNhan" class="text-[#64748b] hover:text-[#3b6cb7] font-medium px-1 py-5 transition">Thông tin cá nhân</a>
                </div>

                <div class="flex items-center gap-4">
                    <div class="text-right hidden md:block">
                        <p class="text-[0.8rem] text-[#64748b] leading-tight">Xin chào,</p>
                        <p class="font-semibold text-[#0f172a] leading-tight">@tenNguoiDung</p>
                    </div>
                    <a href="/Home/DangXuat" class="w-10 h-10 rounded-full bg-red-50 text-red-500 flex items-center justify-center hover:bg-red-500 hover:text-white transition cursor-pointer" title="Đăng xuất">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <h2 class="text-2xl font-bold mb-6 text-[#0f172a] border-l-4 border-[#3b6cb7] pl-3">Lịch Sử Mượn Trả</h2>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-[#e2e8f0] overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-[#f8fafc] border-b border-[#e2e8f0]">
                        <th class="p-4 font-semibold text-[#475569] text-sm">Mã Phiếu</th>
                        <th class="p-4 font-semibold text-[#475569] text-sm">Ngày Mượn</th>
                        <th class="p-4 font-semibold text-[#475569] text-sm">Hạn Trả</th>
                        <th class="p-4 font-semibold text-[#475569] text-sm">Ghi Chú</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var pm in Model)
                        {
                            <tr class="border-b border-[#f1f5f9] hover:bg-[#f8fafc] transition">
                                <td class="p-4 text-[#0f172a] font-medium">@pm.MaPm</td>
                                <td>@pm.NgayHetHan.ToString("dd/MM/yyyy")</td>
                                <td class="p-4 text-red-500 font-semibold">@pm.NgayHetHan.ToString("dd/MM/yyyy")</td>
                                <td class="p-4 text-[#64748b] text-sm">@pm.GhiChu</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-10 text-center text-[#94a3b8]">
                                <i class="fa-solid fa-box-open text-3xl mb-2"></i>
                                <p>Bạn chưa mượn cuốn sách nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>